# Auth
AUTH_PASSWORD=your-shared-password
AUTH_SECRET=random-secret-for-hmac-signing

# Database provider
# Use "neon" before cutover and "turso" after verification passes.
DATABASE_PROVIDER=neon

# Neon / Vercel Postgres
POSTGRES_URL=postgresql://user:password@host/dbname

# Turso / libSQL
TURSO_DATABASE_URL=libsql://your-database-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# File storage provider
# Use "vercel-blob" before cutover and "cloudflare-r2" after R2 credentials/public URL are ready.
STORAGE_PROVIDER=vercel-blob

# Vercel Blob Storage, used only when STORAGE_PROVIDER=vercel-blob or for legacy cleanup
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token

# Cloudflare R2
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=storyboard-assets
R2_PUBLIC_BASE_URL=https://pub-example.r2.dev

# YouTube Data API v3
YOUTUBE_API_KEY=your-youtube-data-api-v3-key

# Google Cloud Vision API (for OCR lyrics extraction)
GOOGLE_CLOUD_VISION_API_KEY=your-google-cloud-vision-api-key

# Google Drive PPTX Export (Service Account)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"...","...":"..."}
GOOGLE_SHEET_ID=your-google-sheet-id
GOOGLE_DRIVE_TEMPLATE_FOLDER_ID=your-google-drive-folder-id
PPTX_SECTION_PREFIX=찬양
PPTX_SCRIPTURE_SECTION_NAME=봉독 말씀

# Client-side PPTX config
NEXT_PUBLIC_PPTX_SECTION_PREFIX=찬양
NEXT_PUBLIC_PPTX_SCRIPTURE_SECTION_NAME=봉독 말씀

# Discord Replacement (somang-discord -> storyboard)
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CHANNEL_ID=your-discord-forum-channel-id
DISCORD_GUILD_ID=your-discord-guild-id
DISCORD_PUBLIC_KEY=your-discord-application-public-key
# Vercel Cron sends Authorization: Bearer $CRON_SECRET automatically.
CRON_SECRET=random-secret-for-vercel-cron-routes
# Legacy/manual fallback accepted by the app, but Vercel Cron itself does not auto-send this name.
DISCORD_CRON_SECRET=random-secret-for-discord-cron-routes
DISCORD_ROLE_OPTIONS=김설교자,박인도자,이찬양
