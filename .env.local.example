# Authentication
# Set a strong random secret for token signing (use any random string)
AUTH_SECRET=your-secret-key-here

# Set the password for login
AUTH_PASSWORD=your-password-here

# Public base URL used by server-side Discord notifications.
APP_BASE_URL=https://your-app-domain.example

# Turso / libSQL
TURSO_DATABASE_URL=libsql://your-database-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Object storage (Cloudflare R2) — used for sheet music and PPTX export downloads
STORAGE_PROVIDER=cloudflare-r2
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
R2_PUBLIC_BASE_URL=https://pub-example.r2.dev

# Google Drive PPTX Export
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"...","...":"..."}
GOOGLE_SHEET_ID=your-google-sheet-id
GOOGLE_DRIVE_TEMPLATE_FOLDER_ID=your-google-drive-folder-id
PPTX_SECTION_PREFIX=찬양
PPTX_SCRIPTURE_SECTION_NAME=봉독 말씀
NEXT_PUBLIC_PPTX_SECTION_PREFIX=찬양
NEXT_PUBLIC_PPTX_SCRIPTURE_SECTION_NAME=봉독 말씀
